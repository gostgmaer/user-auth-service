{
  "name": "user-auth-service",
  "version": "1.0.0",
  "description": "Self-contained user authentication microservice with multi-tenancy support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "pm2 start pm2.config.js --env production",
    "start:dev": "nodemon server.js",
    "dev": "nodemon server.js",
    "stop": "pm2 stop user-auth-service",
    "restart": "pm2 restart user-auth-service",
    "reload": "pm2 reload user-auth-service",
    "logs": "pm2 logs user-auth-service",
    "monit": "pm2 monit",
    "lint": "eslint src/",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "audit:check": "npm audit --audit-level=high",
    "health": "curl -sf http://localhost:4002/health/ready || exit 1"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "morgan": "^1.10.0",
    "otplib": "^12.0.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "ua-parser-js": "^1.0.40",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "pm2": "^6.0.14",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
