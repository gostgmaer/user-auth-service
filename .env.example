# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4002

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For shared multi-tenancy (default): single cluster, tenantId field on every document
MONGO_URI=mongodb://localhost:27017/user_auth_service
# For per-db multi-tenancy: replace {tenant} with actual tenant id at runtime
# MONGO_URI=mongodb://localhost:27017/{tenant}_auth
TENANCY_MODE=shared

# ─── JWT Settings ─────────────────────────────────────────────────────────────
# Minimum 32 characters each. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_32
JWT_ID_SECRET=change_me_id_token_secret_at_least_32_chars_long

JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d
JWT_ID_EXPIRY=30d

JWT_ISSUER=user-auth-service
JWT_AUDIENCE=dashboard-app
JWT_ALGORITHM=HS256

# ─── Token Revocation Store ───────────────────────────────────────────────────
# Options: db | redis
TOKEN_REVOCATION_STORE=db
# Required when TOKEN_REVOCATION_STORE=redis:
# REDIS_URL=redis://localhost:6379

# ─── External Email Microservice ──────────────────────────────────────────────
EMAIL_SERVICE_URL=http://localhost:4003
EMAIL_FROM_ADDRESS=noreply@yourapp.com
EMAIL_FROM_NAME=YourApp

# ─── OTP / MFA ────────────────────────────────────────────────────────────────
TOTP_ISSUER=YourApp
OTP_EXPIRY_MINUTES=10

# SMS (optional — Twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
PASSWORD_RESET_EXPIRY_HOURS=1
EMAIL_VERIFY_EXPIRY_HOURS=24

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# ─── Frontend (used in email links) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
