# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4002

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For shared multi-tenancy (default): single cluster, tenantId field on every document
MONGO_URI=mongodb://localhost:27017/user_auth_service
# For per-db multi-tenancy: replace {tenant} with actual tenant id at runtime
# MONGO_URI=mongodb://localhost:27017/{tenant}_auth
TENANCY_MODE=shared
# Enforce tenant scoping on every request.
# true  → resolve tenant from x-tenant-id (fallback DEFAULT_TENANT_ID=easydev).
# false → do not resolve/check tenant; ignore x-tenant-id even if provided.
TENANCY_ENABLED=true
# Fallback tenant when x-tenant-id header is absent.
# For single-tenant: set to your slug. For strict enforcement: leave blank.
DEFAULT_TENANT_ID=easydev

# ─── JWT Settings ─────────────────────────────────────────────────────────────
# Minimum 32 characters each. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_32
JWT_ID_SECRET=change_me_id_token_secret_at_least_32_chars_long

# Production recommendation: short-lived access tokens (15m), longer refresh (7d)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ID_EXPIRY=30d

JWT_ISSUER=user-auth-service
JWT_AUDIENCE=dashboard-app
# Options: HS256 | HS384 | HS512 | RS256 | RS384 | RS512
JWT_ALGORITHM=HS256

# For RS256/RS384/RS512: paths to PEM files (leave blank for HMAC)
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# ─── Token Revocation Store ───────────────────────────────────────────────────
# Options: db | redis (redis recommended for production clusters)
TOKEN_REVOCATION_STORE=db
# Required when TOKEN_REVOCATION_STORE=redis:
# REDIS_URL=redis://localhost:6379

# ─── External Email Microservice ──────────────────────────────────────────────
EMAIL_SERVICE_URL=http://localhost:4003
EMAIL_FROM_ADDRESS=noreply@yourapp.com
EMAIL_FROM_NAME=YourApp
# Admin inbox that receives new-user registration notifications
ADMIN_EMAIL=admin@yourapp.com

# ─── OTP / MFA ────────────────────────────────────────────────────────────────
TOTP_ISSUER=YourApp
OTP_EXPIRY_MINUTES=10
ENABLE_OTP_VERIFICATION=false

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
PASSWORD_RESET_EXPIRY_HOURS=1
EMAIL_VERIFY_EXPIRY_HOURS=24

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# ─── Frontend (used in email links) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: json | pretty (use json in production for log aggregators)
LOG_FORMAT=json
# Set to true to write rotating log files in addition to stdout
LOG_TO_FILE=false
LOG_DIR=logs

# ─── Observability ────────────────────────────────────────────────────────────
# Bearer token required to scrape GET /health/metrics (Prometheus endpoint).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank to disable authentication on the metrics endpoint (not recommended in production)
METRICS_SECRET=

# ─── Background jobs ──────────────────────────────────────────────────────────
CLEANUP_ENABLED=true

# ─── Cluster / PM2 ────────────────────────────────────────────────────────────
# Number of worker processes. 'max' uses all CPU cores (default in pm2.config.js).
# WEB_CONCURRENCY=max

# ─── Rate limiting (optional overrides) ──────────────────────────────────────
# LOGIN_RATE_LIMIT=10
# LOGIN_RATE_WINDOW_MS=900000
# REGISTER_RATE_LIMIT=5
# REGISTER_RATE_WINDOW_MS=3600000
# OTP_RATE_LIMIT=5
# OTP_RATE_WINDOW_MS=3600000
# RESET_RATE_LIMIT=3
# RESET_RATE_WINDOW_MS=3600000
